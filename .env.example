# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DEEPSEEK_API_KEY: Optional/Required for DeepSeek AI engine.
# Configure this to enable the real DeepSeek delegation agent.
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloudflare R2 configuration details
R2_ACCOUNT_ID="YOUR_R2_ACCOUNT_ID"
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
R2_BUCKET_NAME="YOUR_R2_BUCKET_NAME"
R2_PUBLIC_URL="YOUR_R2_PUBLIC_URL" # e.g. https://pub-xxxx.r2.dev or a custom domain

# Postiz REST API configuration
POSTIZ_API_KEY="YOUR_POSTIZ_API_KEY"
POSTIZ_API_URL="https://api.postiz.com/public/v1"

# Supabase database configuration
SUPABASE_URL="https://linjrrwcqzviqxetbail.supabase.co"
SUPABASE_KEY="YOUR_SUPABASE_ANON_KEY"


